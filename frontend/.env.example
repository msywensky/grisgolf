# Copy to .env and fill in from your Supabase project (Settings → API)
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# This is the "Publishable key" (sb_publishable_...) in newer Supabase projects,
# formerly called "anon" — safe to expose in the browser, gated by RLS.
PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
# FastAPI backend (local default shown; use your Railway/Render URL in prod)
PUBLIC_API_URL=http://localhost:8000
