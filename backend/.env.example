# Copy to .env and fill in from your Supabase project (Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# This is the "Secret key" (sb_secret_...) in newer Supabase projects,
# formerly called "service_role" — server-side only, never ship to the frontend!
SUPABASE_SERVICE_ROLE_KEY=your-secret-key
# Comma-separated origins allowed to call this API
CORS_ORIGINS=http://localhost:5173
# Free API key from https://golfcourseapi.com (sign up with email).
# Optional — without it, course search degrades to already-cached courses
# and organizers can still type a course name by hand.
GOLF_COURSE_API_KEY=
